#: reqlock.php:247
msgid "Block all external requests (allow-list exceptions)"
msgstr "Bloquer toutes les requêtes externes (exceptions via la liste d’autorisation)"

#: reqlock.php:248
msgid "Block only listed hosts (block-list)"
msgstr "Bloquer uniquement les hôtes listés (liste de blocage)"

#: reqlock.php:418
#, php-format
msgid "Plugin: %s"
msgstr "Extension : %s"

#: reqlock.php:422
