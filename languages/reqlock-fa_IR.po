#: reqlock.php:247
msgid "Block all external requests (allow-list exceptions)"
msgstr "مسدودکردن همهٔ درخواست‌های خارجی (به‌جز فهرست مجاز)"

#: reqlock.php:248
msgid "Block only listed hosts (block-list)"
msgstr "فقط مسدودکردن میزبان‌های فهرست‌شده (فهرست مسدود)"

#: reqlock.php:418
#, php-format
msgid "Plugin: %s"
msgstr "افزونه: %s"

#: reqlock.php:422
#, php-format
msgid "Theme: %s"
msgstr "پوسته: %s"

#: reqlock.php:426
#, php-format
msgid "Front-end (%s)"
msgstr "بخش کاربری (%s)"

#: reqlock.php:429
msgid "WordPress core"
msgstr "هستهٔ وردپرس"

#: reqlock.php:430
msgid "Must-use plugin"
msgstr "افزونهٔ اجباری (mu-plugin)"

#: reqlock.php:431
msgid "Front-end"
msgstr "بخش کاربری"

#: reqlock.php:432
msgid "Unknown"
msgstr "نامشخص"

#: reqlock.php:767 reqlock.php:807
msgid "Could not locate wp-config.php."
msgstr "فایل wp-config.php پیدا نشد."

#: reqlock.php:770
msgid "wp-config.php is not writable — comment out the WP_HTTP_BLOCK_EXTERNAL line manually."
msgstr "فایل wp-config.php قابل نوشتن نیست — خط WP_HTTP_BLOCK_EXTERNAL را به‌صورت دستی کامنت کنید."

#: reqlock.php:774 reqlock.php:814
msgid "Could not read wp-config.php."
msgstr "خواندن wp-config.php ممکن نشد."

#: reqlock.php:784
msgid "No active WP_HTTP_BLOCK_EXTERNAL found to disarm."
msgstr "هیچ WP_HTTP_BLOCK_EXTERNAL فعالی برای غیرفعال‌سازی پیدا نشد."

#: reqlock.php:788 reqlock.php:828
msgid "Safety check failed — wp-config.php was left unchanged."
msgstr "بررسی ایمنی ناموفق بود — wp-config.php بدون تغییر باقی ماند."

#: reqlock.php:793 reqlock.php:833
msgid "Failed to write wp-config.php."
msgstr "نوشتن در wp-config.php ناموفق بود."

#: reqlock.php:795
msgid "WP_HTTP_BLOCK_EXTERNAL has been commented out in wp-config.php. ReqLock now controls external blocking — turn the master switch ON to block."
msgstr "خط WP_HTTP_BLOCK_EXTERNAL در wp-config.php کامنت شد. اکنون مسدودسازی خارجی توسط ReqLock کنترل می‌شود — برای مسدودسازی، کلید اصلی را روشن کنید."

#: reqlock.php:810
msgid "wp-config.php is not writable — edit it manually."
msgstr "فایل wp-config.php قابل نوشتن نیست — آن را به‌صورت دستی ویرایش کنید."

#: reqlock.php:824
msgid "No ReqLock-disarmed WP_HTTP_BLOCK_EXTERNAL found to restore."
msgstr "هیچ WP_HTTP_BLOCK_EXTERNAL غیرفعال‌شده توسط ReqLock برای بازگردانی پیدا نشد."

#: reqlock.php:835
msgid "WP_HTTP_BLOCK_EXTERNAL restored in wp-config.php — WordPress now blocks all external requests again, independent of ReqLock."
msgstr "خط WP_HTTP_BLOCK_EXTERNAL در wp-config.php بازگردانده شد — اکنون وردپرس دوباره همهٔ درخواست‌های خارجی را مستقل از ReqLock مسدود می‌کند."

#: reqlock.php:856
msgid "Settings"
msgstr "تنظیمات"

#: reqlock.php:871
msgid "ReqLock firewall is ON — external requests are being blocked"
msgstr "فایروال ReqLock روشن است — درخواست‌های خارجی مسدود می‌شوند"

#: reqlock.php:875
msgid "ReqLock firewall is OFF — optimizers are active (localize / lazy-load)"
msgstr "فایروال ReqLock خاموش است — بهینه‌سازها فعال‌اند (محلی‌سازی / بارگذاری تنبل)"

#: reqlock.php:878
msgid "ReqLock is idle — firewall off, no optimizers active"
msgstr "ReqLock بی‌کار است — فایروال خاموش، هیچ بهینه‌سازی فعال نیست"

#: reqlock.php:932
msgid "Detected-hosts list cleared."
msgstr "لیست میزبان‌های شناسایی‌شده پاک شد."

#: reqlock.php:979
msgid "Saved — ReqLock is ON (external requests blocked)."
msgstr "تنظیمات ذخیره شد — ReqLock فعال است (درخواست‌های خارجی مسدود)."

#: reqlock.php:980
msgid "Saved — ReqLock is OFF."
msgstr "تنظیمات ذخیره شد — ReqLock غیرفعال است."

#: reqlock.php:990
#, php-format
msgid "⚠ Block-list: %1$d entry was removed. The free version allows up to %2$d exact host(s) and no wildcard (*.example.com) subdomains. Upgrade to ReqLock Pro for unlimited hosts and wildcard subdomains."
msgid_plural "⚠ Block-list: %1$d entries were removed. The free version allows up to %2$d exact host(s) and no wildcard (*.example.com) subdomains. Upgrade to ReqLock Pro for unlimited hosts and wildcard subdomains."
msgstr[0] "⚠ فهرست مسدود: %1$d مورد حذف شد. نسخهٔ رایگان تا %2$d میزبانِ دقیق را مجاز می‌داند و زیردامنهٔ وایلدکارت (*.example.com) را پشتیبانی نمی‌کند. برای میزبان نامحدود و زیردامنهٔ وایلدکارت به ReqLock Pro ارتقا دهید."
msgstr[1] "⚠ فهرست مسدود: %1$d مورد حذف شد. نسخهٔ رایگان تا %2$d میزبانِ دقیق را مجاز می‌داند و زیردامنهٔ وایلدکارت (*.example.com) را پشتیبانی نمی‌کند. برای میزبان نامحدود و زیردامنهٔ وایلدکارت به ReqLock Pro ارتقا دهید."

#: reqlock.php:1083
msgid "ACTIVE"
msgstr "فعال"

#: reqlock.php:1083
msgid "OFF"
msgstr "غیرفعال"

#: reqlock.php:1084
msgid "An outbound (egress) firewall. Turn the master switch ON to block all external server-side and browser-side calls. Three uses in one switch — resilience when the internet is cut/restricted, performance (slow or dead third-party calls fail instantly instead of stalling page loads), and privacy (strip trackers and phone-home requests)."
msgstr "فایروالِ درخواست‌های خروجی. با روشن‌کردن کلید اصلی، همهٔ فراخوانی‌های خارجیِ سمت سرور و سمت مرورگر مسدود می‌شوند. سه کاربرد در یک کلید — تاب‌آوری هنگام قطع/محدودیت اینترنت، کارایی (درخواست‌های کند یا بی‌پاسخِ شخص‌ثالث به‌جای معطل‌کردن بارگذاری صفحه، فوری ناموفق می‌شوند)، و حریم خصوصی (حذف ردیاب‌ها و فراخوانی‌های phone-home)."

#: reqlock.php:1092
msgid "Master switch — Block external requests"
msgstr "کلید اصلی — مسدودسازی درخواست‌های خارجی"

#: reqlock.php:1093
msgid "When ON, blocking is applied per the options below."
msgstr "وقتی روشن باشد، مسدودسازی طبق گزینه‌های زیر اعمال می‌شود."

#: reqlock.php:1097
msgid "Mode"
msgstr "حالت"

#: reqlock.php:1105
msgid "“Block all external” blocks every outside host except your allow-list. “Block-list” keeps the site online and blocks only the hosts you list below. Your own domain and subdomains are never blocked."
msgstr "«مسدودکردن همهٔ خارجی» همهٔ میزبان‌های خارجی را به‌جز فهرست مجاز شما مسدود می‌کند. «فهرست مسدود» سایت را آنلاین نگه می‌دارد و فقط میزبان‌هایی را که در پایین فهرست می‌کنید مسدود می‌کند. دامنهٔ خودتان و زیردامنه‌هایش هرگز مسدود نمی‌شوند."

#: reqlock.php:1110
msgid "Server-side"
msgstr "سمت سرور"

#: reqlock.php:1112
msgid "Block outbound WP HTTP API"
msgstr "مسدودسازی درخواست‌های خروجی WP"

#: reqlock.php:1113
msgid "Updates, wordpress.org, OpenAI/Gemini, any wp_remote_*. Fails instantly instead of timing out."
msgstr "به‌روزرسانی‌ها، wordpress.org، OpenAI/Gemini و هر wp_remote_*. به‌جای تایم‌اوت، فوری ناموفق می‌شود."

#: reqlock.php:1117
msgid "Browser-side"
msgstr "سمت مرورگر"

#: reqlock.php:1118
msgid "External <script src>"
msgstr "اسکریپت‌های خارجی"

#: reqlock.php:1118
msgid "Removes external JavaScript files."
msgstr "حذف اسکریپت‌های بارگذاری‌شده از دامنه‌های دیگر."

#: reqlock.php:1119
msgid "External stylesheets"
msgstr "استایل‌های خارجی"

#: reqlock.php:1119
msgid "Removes external stylesheets (e.g. Google Fonts)."
msgstr "حذف استایل‌های خارجی (مثل Google Fonts)."

#: reqlock.php:1120
msgid "External resource hints"
msgstr "Resource hints خارجی"

#: reqlock.php:1120
msgid "Removes preconnect / dns-prefetch / preload / prefetch to external hosts."
msgstr "حذف preconnect / dns-prefetch / preload / prefetch به دامنه‌های خارجی."

#: reqlock.php:1121
msgid "External iframes"
msgstr "iframeهای خارجی"

#: reqlock.php:1121
msgid "Replaces external iframes with a local placeholder."
msgstr "جایگزینی iframe خارجی با یک جای‌نگه‌دار محلی."

#: reqlock.php:1122
msgid "Inline analytics"
msgstr "اسنیپت‌های تحلیلی درون‌خطی"

#: reqlock.php:1122
msgid "Removes inline GA/GTM/Clarity/Ahrefs/Pixel snippets."
msgstr "حذف اسنیپت‌های GA/GTM/Clarity/Ahrefs/Pixel که مستقیم در صفحه نوشته شده‌اند."

#: reqlock.php:1123
msgid "External images"
msgstr "تصاویر خارجی"

#: reqlock.php:1123
msgid "Replaces external images with a transparent placeholder. (off by default)"
msgstr "جایگزینی تصاویر خارجی با تصویر شفاف. (پیش‌فرض خاموش)"

#: reqlock.php:1127
msgid "Scope & logging"
msgstr "دامنه و ثبت"

#: reqlock.php:1128
msgid "Also sanitize wp-admin"
msgstr "اعمال در پیشخوان"

#: reqlock.php:1128
msgid "Off by default — to avoid disrupting wp-admin."
msgstr "پیش‌فرض خاموش — برای جلوگیری از به‌هم‌ریختن پیشخوان."

#: reqlock.php:1129
msgid "Log detected hosts"
msgstr "ثبت میزبان‌های شناسایی‌شده"

#: reqlock.php:1129
msgid "Keeps a list of detected external hosts."
msgstr "فهرست دامنه‌های خارجی شناسایی‌شده را نگه می‌دارد."

#: reqlock.php:1134
msgid "Allow-list"
msgstr "فهرست مجاز"

#: reqlock.php:1135
msgid "Hosts to always allow (one per line or comma-separated). Your own domain and its subdomains are always allowed."
msgstr "دامنه‌هایی که باید همیشه مجاز بمانند (یکی در هر خط یا با کاما). دامنهٔ خود سایت و زیردامنه‌هایش همیشه مجاز است."

#: reqlock.php:1140
msgid "Block-list"
msgstr "فهرست مسدود"

#: reqlock.php:1141
msgid "Hosts to block when Mode is “Block-list” (one per line or comma-separated). Ignored in “Block all external” mode. Your own domain and its subdomains are never blocked. The free version blocks up to 2 exact hosts."
msgstr "میزبان‌هایی که وقتی حالت روی «فهرست مسدود» است مسدود می‌شوند (هر کدام در یک خط یا جداشده با کاما). در حالت «مسدودکردن همهٔ خارجی» نادیده گرفته می‌شود. دامنهٔ خودتان و زیردامنه‌هایش هرگز مسدود نمی‌شوند. نسخهٔ رایگان تا ۲ میزبانِ دقیق را مسدود می‌کند."

#: reqlock.php:1143
msgid "<strong>ReqLock Pro</strong>: unlimited hosts, <code>*.example.com</code> wildcard subdomains, auto-block slow hosts, and localize external fonts/JS/CSS."
msgstr "<strong>ReqLock Pro</strong>: میزبان نامحدود، زیردامنهٔ وایلدکارت <code>*.example.com</code>، مسدودسازی خودکار میزبان‌های کند، و محلی‌سازی فونت/JS/CSS خارجی."

#: reqlock.php:1143 reqlock.php:1228
msgid "Learn more"
msgstr "اطلاعات بیشتر"

#: reqlock.php:1147
msgid "Save settings"
msgstr "ذخیره تنظیمات"

#: reqlock.php:1152
msgid "Detected external hosts"
msgstr "میزبان‌های خارجی شناسایی‌شده"

#: reqlock.php:1154
msgid "Nothing logged yet. While active, blocked external hosts appear here as visitors load pages — use them to build your allow-list."
msgstr "هنوز موردی ثبت نشده. وقتی فعال باشد و کسی از سایت بازدید کند، میزبان‌های خارجیِ مسدودشده اینجا فهرست می‌شوند — از آن‌ها برای ساختن فهرست مجاز استفاده کنید."

#: reqlock.php:1157
msgid "Source"
msgstr "منبع"

#: reqlock.php:1157
msgid "First seen"
msgstr "اولین شناسایی"

#: reqlock.php:1175
msgid "Clear list"
msgstr "پاک کردن فهرست"

#: reqlock.php:1183
msgid "External HTTP block (wp-config.php)"
msgstr "مسدودسازی HTTP خارجی (wp-config.php)"

#: reqlock.php:1184
msgid "ReqLock should be the single switch for external blocking. A hardcoded WP_HTTP_BLOCK_EXTERNAL blocks requests even when ReqLock is OFF (breaking plugin/theme installs, updates, and the directory) — disarm it so ReqLock controls blocking. You can re-arm (restore) it at any time."
msgstr "ReqLock باید تنها کلید کنترل مسدودسازی خارجی باشد. مقدار ثابتِ WP_HTTP_BLOCK_EXTERNAL حتی وقتی ReqLock خاموش است درخواست‌ها را مسدود می‌کند (و نصب افزونه/قالب، به‌روزرسانی‌ها و مخزن را مختل می‌کند) — آن را غیرفعال کنید تا مسدودسازی توسط ReqLock کنترل شود. هر زمان می‌توانید دوباره آن را فعال (بازگردانی) کنید."

#: reqlock.php:1189
msgid "Hardcoded block"
msgstr "مسدودسازی ثابت (هاردکد)"

#: reqlock.php:1189
msgid "Location"
msgstr "محل"

#: reqlock.php:1189
msgid "Action"
msgstr "عملیات"

#: reqlock.php:1197
msgid "Disarm (comment out)"
msgstr "غیرفعال‌سازی (کامنت‌کردن)"

#: reqlock.php:1199
msgid "Re-arm (restore block)"
msgstr "فعال‌سازی مجدد (بازگردانی مسدودسازی)"

#: reqlock.php:1201
msgid "review manually"
msgstr "بررسی دستی"

#: reqlock.php:1203
msgid "not writable — edit manually"
msgstr "غیرقابل نوشتن — ویرایش دستی"

#: reqlock.php:1226
msgid "Upgrade to ReqLock Pro"
msgstr "ارتقا به ReqLock Pro"

#: reqlock.php:1227
msgid "Localize external fonts, JS & CSS (GDPR-friendly, faster), lazy-load embeds & images, auto-block slow hosts, an unlimited + wildcard block-list, and serve cached resources during an outage so your site keeps working."
msgstr "محلی‌سازی فونت، JS و CSS خارجی (سازگار با GDPR و سریع‌تر)، بارگذاری تنبلِ امبدها و تصاویر، مسدودسازی خودکار میزبان‌های کند، فهرست مسدودِ نامحدود و وایلدکارت، و ارائهٔ منابع کش‌شده هنگام قطعی اینترنت تا سایت شما به کار ادامه دهد."

#: reqlock.php:1238
msgid "Developed and maintained by the <strong>Rackset DevOps Team</strong>."
msgstr "توسعه و نگهداری‌شده توسط <strong>تیم دواپس رک‌ست</strong>."

#: reqlock.php:1239
msgid "Website:"
msgstr "وب‌سایت:"

#~ msgid "ReqLock active — external requests blocked"
#~ msgstr "ReqLock فعال — درخواست‌های خارجی مسدود است"
