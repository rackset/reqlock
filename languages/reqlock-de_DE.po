#: reqlock.php:247
msgid "Block all external requests (allow-list exceptions)"
msgstr "Alle externen Anfragen blockieren (Ausnahmen per Erlaubnisliste)"

#: reqlock.php:248
msgid "Block only listed hosts (block-list)"
msgstr "Nur aufgeführte Hosts blockieren (Sperrliste)"

#: reqlock.php:418
#, php-format
msgid "Plugin: %s"
msgstr "Plugin: %s"

